# === FastChecker - Configuracion ===

# Anthropic API Key (REQUERIDA)
# Obten la tuya en: https://console.anthropic.com/settings/keys
# Necesitas agregar creditos ($5 USD minimo) en Settings > Billing
ANTHROPIC_API_KEY=sk-ant-api03-tu-key-aqui

# Puerto del servidor (opcional, default: 3001)
PORT=3001

# Modelo de Claude (opcional, default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Tamano maximo de imagen en bytes (opcional, default: 5242880 = 5MB)
MAX_IMAGE_SIZE=5242880

# Limite de requests por minuto por IP (opcional, default: 10)
RATE_LIMIT_RPM=10

# Origenes CORS permitidos (opcional, default: http://localhost:5173)
# Separar multiples origenes con coma
ALLOWED_ORIGINS=http://localhost:5173
